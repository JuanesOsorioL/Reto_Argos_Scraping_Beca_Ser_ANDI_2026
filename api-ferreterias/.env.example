# ============================================================
# BASE DE DATOS
#
# Si corres la API LOCALMENTE (fuera de Docker):
#   El postgres de tu docker-compose expone el puerto 1111
#   DATABASE_URL=postgresql://postgres:1234@localhost:1111/postgres
#
# Si corres la API DENTRO de Docker (recomendado):
#   DATABASE_URL=postgresql://postgres:1234@postgressArgos:5432/postgres
# ============================================================
DATABASE_URL=

# ============================================================
# OPENROUTER - IA GRATUITA
# Registro gratis: https://openrouter.ai/keys
# ============================================================
OPENROUTER_API_KEY=

# ============================================================
# ANTHROPIC CLAUDE - Opcional, fallback de pago
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# SERPER - Busqueda Google (2500 busquedas/mes gratis)
# https://serper.dev
# ============================================================
SERPER_API_KEY=

# ============================================================
# N8N WEBHOOK - URL donde n8n recibe la notificacion
# Local:  http://localhost:2222/webhook/Ferreterias
# Docker: http://Argos_n8n:5678/webhook/Ferreterias
# ============================================================
N8N_WEBHOOK_URL=
API_BASE_URL=

# ============================================================
# PIPELINE
# ============================================================
USAR_IA_DUPLICADOS=true
PREFERIR_OPENROUTER=true
INCLUIR_RUES_INACTIVOS=true
CREAR_JSON_CAMPOS_DUDOSOS=true
CREAR_JSON_POSIBLES_MATCHES=true
CREAR_CSV_CLEAN_EMPRESAS=false
CREAR_EXCEL_CLEAN_EMPRESAS=false

# ============================================================
# SERVIDOR LOCAL
# ============================================================
# Schema de tablas fuente
# raw      = produccion (datos completos)
# rawantes = prueba/backup (muestra)
RAW_SCHEMA=raw

ENVIRONMENT=dev
LOG_LEVEL=INFO
API_PORT=8000
