# ─────────────────────────────────────────────────────────────────────────────
# .env — Foursquare Places API con Pausa Automática por Rate Limits
# ─────────────────────────────────────────────────────────────────────────────

# ══ BASE DE DATOS POSTGRESQL ══════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=1234

# ══ FOURSQUARE API ═════════════════════════════════════════════════════════════
FSQ_API_KEY=

# ══ CONTROL DE PAUSA AUTOMÁTICA POR RATE LIMITS ═══════════════════════════════
# ✅ AUTO_PAUSE_ON_RATE_LIMIT
#    - true:  Si llega 403 (rate limit), pausa automáticamente
#    - false: Ignora 403 y continúa normalmente
AUTO_PAUSE_ON_RATE_LIMIT=true

# ✅ RATE_LIMIT_SLEEP_SECONDS
#    - Cuántos segundos esperar cuando se detecta 403
#    - Foursquare reset: cada hora (3600 segundos)
#    - Recomendado: 3600 (1 hora) o 1800 (30 minutos) para no perder queries
RATE_LIMIT_SLEEP_SECONDS=3600

# ✅ MAX_CONSECUTIVE_RATE_LIMITS
#    - Máximo número de veces que se puede pausar antes de detener completamente
#    - Evita loops infinitos
#    - Recomendado: 5-10
MAX_CONSECUTIVE_RATE_LIMITS=5

# ✅ AUTO_RESUME_AFTER_PAUSE
#    - true:  Después de esperar, reintenta automáticamente
#    - false: Se queda pausado (manual resume por n8n)
AUTO_RESUME_AFTER_PAUSE=true

# ══ CONTROL DE JSON BACKUP ═════════════════════════════════════════════════════
# ✅ SAVE_JSON_BACKUP
#    - true:  Guarda foursquare_raw_responses.json y foursquare_flat_results.json
#    - false: No guarda JSONs (ahorra espacio, todo en PostgreSQL)
SAVE_JSON_BACKUP=false

# ✅ SAVE_PROGRESS_FILE
#    - true:  Guarda foursquare_progress.json con estado actual
#    - false: No guarda archivo de progreso
SAVE_PROGRESS_FILE=false

# ════════════════════════════════════════════════════════════════════════════════
# WEBHOOKS PARA NOTIFICACIONES A N8N ═════════════════════════════════════════════
# ════════════════════════════════════════════════════════════════════════════════

# ✅ WEBHOOK_ON_PAUSE
#    URL donde n8n escucha cuando la API se pausa
#    Ejemplo: http://n8n.tu-dominio.com/webhook/foursquare-pause
#    Si está vacío, no se envían webhooks al pausar
WEBHOOK_ON_PAUSE=http://localhost:5678/webhook/foursquare-pause

# ✅ WEBHOOK_ON_COMPLETE
#    URL donde n8n escucha cuando se completa la corrida
#WEBHOOK_ON_COMPLETE=http://localhost:5678/webhook/foursquare-complete

WEBHOOK_ON_COMPLETE=http://Argos_n8n:5678/webhook/foursquare-complete

# ✅ WEBHOOK_ON_ERROR
#    URL donde n8n escucha si hay error fatal
WEBHOOK_ON_ERROR=http://localhost:5678/webhook/foursquare-error

# ════════════════════════════════════════════════════════════════════════════════
# SERVIDOR HTTP (FASTAPI) ═════════════════════════════════════════════════════════
# ════════════════════════════════════════════════════════════════════════════════

# ✅ API_PORT
#    Puerto donde corre la API FastAPI
#    - Docker: 8006
#    - Local: 8006
API_PORT=8005

# ✅ API_HOST
#    Host donde escucha la API
#    - 0.0.0.0: Acepta conexiones externas (Docker)
#    - localhost: Solo local
API_HOST=0.0.0.0

# ════════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN AVANZADA ══════════════════════════════════════════════════════════
# ════════════════════════════════════════════════════════════════════════════════

# ✅ DEBUG
#    true: Imprime mucho detalle (desarrollo)
#    false: Solo lo importante (producción)
DEBUG=true

# ✅ REQUEST_DELAY_SECONDS
#    Retraso entre requests a Foursquare (segundos)
#    Recomendado: 0.2-0.5 para no saturar
REQUEST_DELAY_SECONDS=0.3

# ✅ MAX_RETRIES
#    Máximo de reintentos por request fallido
MAX_RETRIES=3

# ════════════════════════════════════════════════════════════════════════════════
# DOCUMENTACIÓN DE LÍMITES (Para referencia)
# ════════════════════════════════════════════════════════════════════════════════
# Foursquare Places API (tier gratuito):
#   - 5.000 requests sin usuario/hora a /places/* endpoints
#   - 500 requests sin usuario/hora a otros endpoints
#   - Respuesta 403 = Límite alcanzado
#   - Header X-RateLimit-Reset = UNIX timestamp cuando se resetea
# 
# Estrategia de pausa:
#   1. Detectar 403 en respuesta
#   2. Leer X-RateLimit-Reset del header
#   3. Calcular cuánto tiempo esperar
#   4. Pausar y guardar estado en foursquare_progress.json
#   5. Enviar webhook a n8n
#   6. Cuando reset, reanudar automáticamente
# ════════════════════════════════════════════════════════════════════════════════
